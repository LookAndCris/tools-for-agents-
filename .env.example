# Copy this file to .env and set values for your local environment.
# Never commit .env to version control.

# Async PostgreSQL connection URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tools_for_agents

# Runtime environment: development | staging | production
APP_ENV=development

# OpenAI API key for the chat conversation loop (scripts/run_chat.py)
OPENAI_API_KEY=sk-your-key-here
